+#define MAX_NR_FREQ      32 /* Max supported number of frequency */
+#define VOLT_STEP    625
+
+enum eemsn_det_id {
+	EEMSN_DET_L = 0,
+	EEMSN_DET_BL, /* for BL or B */
+	EEMSN_DET_B, /* for B or DSU */
+	EEMSN_DET_CCI,
+
+	NR_EEMSN_DET,
+};
+
+/* Parameter Enum */
+enum {
+	IPI_EEMSN_GET_EEM_VOLT = 4,
+	NR_EEMSN_IPI = 24,
+};
+
+struct eemsn_ipi_data {
+	unsigned int cmd;
+	union {
+		struct {
+			unsigned int arg[3];
+		} data;
+	} u;
+};
+
