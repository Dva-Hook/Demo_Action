+static void uag_gov_irq_work(struct irq_work *irq_work)
+{
+	struct uag_gov_policy *sg_policy;
+
+	sg_policy = container_of(irq_work, struct uag_gov_policy, irq_work);
+
+	kthread_queue_work(&sg_policy->worker, &sg_policy->work);
+}
