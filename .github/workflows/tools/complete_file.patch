+	if (max_item_cnt < 0 || max_item_cnt > BINDER_STATS_MAX_COUNT_LIMIT) {
+		BINDER_STATS_LOGE("invalid max_item_cnt!\n");
+		return -1;
+	}
+
+	context_ptr->max_item_cnt = max_item_cnt;
+
+	return 0;
+}
