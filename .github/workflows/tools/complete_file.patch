+	struct walt_cpu_load	walt_load;
+	unsigned int		reasons;
+#endif /* CONFIG_ARCH_MEDIATEK */
+	struct uag_gov_policy	*sg_policy;
+	unsigned int		cpu;
+
+	bool			iowait_boost_pending;
+	unsigned int		iowait_boost;
+	u64			last_update;
+
+	unsigned long		bw_dl;
+	unsigned long		max;
+	unsigned long		util;
+	unsigned int		flags;
+};
