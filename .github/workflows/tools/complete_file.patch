+/*
+ * binder_stats : user space mmap the buffer struct.
+ * this struct buffer is dynamic alloc,
+ * items size is max_item_cnt, it is config by user.
+ * items size BINDER_STATS_MAX_COUNT_LIMIT is invalid.
+ */
