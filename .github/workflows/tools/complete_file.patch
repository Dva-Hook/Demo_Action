+
+void  ux_throttle_handler(struct task_struct *tsk)
+{
+	u32 idx, cpu;
+	static int ux_throttle_counter;
+	struct cpufreq_policy *policy;
+	struct ux_throttle_struct *cur;
+	struct timespec64 ts;
+
+	if (is_task_traced(tsk, &idx) && tsk->on_cpu) {
+		cur = &ux_throttle_struct[(ux_throttle_counter++)%THROTTLE_TRACK_NUM];
+		ktime_get_real_ts64(&ts);
+		cur->time_stamp.tv_sec = ts.tv_sec;
+		cur->time_stamp.tv_nsec = ts.tv_nsec;
+		cpu = task_cpu(tsk);
+		cur->core_id = cpu;
+		policy = cpufreq_cpu_get(cpu);
+		if (unlikely(!policy))
+			return;
+		cur->freq = policy->cur;
+		cur->max_freq = policy->max;
+		cur->pid = tsk->pid;
+		memcpy(cur->comm, tsk->comm, TASK_COMM_LEN);
+		cpufreq_cpu_put(policy);
+	}
+}
+
+void osi_scheduler_tick_handler(void *unused, struct rq *rq)
+{
+	struct oplus_task_struct *ots = get_oplus_task_struct(rq->curr);
+	unsigned int limit;
+	if (unlikely(!ots))
+		return;
+	limit = ux_task_exec_limit(rq->curr);
+	if (ots->total_exec > limit) {
+		ux_throttle_handler(rq->curr);
+	}
+}
