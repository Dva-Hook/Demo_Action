+		.limit_level   = 8,
+		.down_speed    = 2,
+		.up_speed      = 1,
+		.freqs_resident[0 ... NR_FREQ - 1] = -1,
+		.freqs[0 ... NR_FREQ - 1] = FREQ_QOS_MAX_DEFAULT_VALUE,
+	},
+	/* gold prime */
+	{
+		.first_cpu     = -1,
+		.enable        = true,
+		.down_limit_ns = 50 * NSEC_PER_MSEC,
+		.up_limit_ns   = 50 * NSEC_PER_MSEC,
+		.limit_thres   = 30 * NSEC_PER_MSEC,
