+struct oplus_ipa_param {
+	s64 err_integral;
+	s32 prev_err;
+	int trip_switch_on;
+	int trip_control_temp;
+
+	u32 sustainable_power;
+	s32 k_po;
+	s32 k_pu;
+	s32 k_i;
+	s32 k_d;
+	s32 i_max;
+	s32 integral_cutoff;
+
+	int polling_delay_on;
+	int polling_delay_off;
+
+	bool switched_on;
+	bool use_power_budget;
