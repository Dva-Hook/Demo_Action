+
+	/* TODO: find related threads and set them as frame task
+	 * if (r_depth > 0 && r_width > 0) {
+	 * }
+	 */
+
+	success = true;
+out:
+	rcu_read_unlock();
+	if (task_removed) {
+		put_task_struct(task_removed);
+	}
+	return success;
