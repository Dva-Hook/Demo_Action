+
+	/* Wait list nums stats. */
+	raw_spin_lock(&sem->wait_lock);
+	record_waiters_cnts(sem, RWSEM);
+	// walk_list_for_elem_nums(&sem->wait_list);
+	raw_spin_unlock(&sem->wait_lock);
+}
