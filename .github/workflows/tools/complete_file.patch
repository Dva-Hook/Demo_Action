diff --git a/kernel/oplus_cpu/sched/frame_boost/frame_boost_trace.h b/kernel/oplus_cpu/sched/frame_boost/frame_boost_trace.h
new file mode 100755
index 0000000000000..c343bdecd4643
--- /dev/null
