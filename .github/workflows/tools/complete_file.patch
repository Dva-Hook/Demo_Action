+	if (unlikely(global_debug_enabled & DEBUG_SYSTRACE)) {
+		ux_state_systrace_c(cpu_of(rq), next);
+		if (likely(prev != next)) {
+			sched_info_systrace_c(cpu_of(rq), next);
+			qs_info_systrace_c(cpu_of(rq), next);
+		}
+	}
