+#define MAX_CTP_WINDOW_TICK (10 * NSEC_PER_SEC / TICK_NSEC)
+
+#define power_debug_attr(_name) \
+static struct kobj_attribute _name##_attr = {	\
+	.attr	= {				\
+		.name = __stringify(_name),	\
+		.mode = 0644,			\
+	},					\
+	.show	= _name##_show,			\
