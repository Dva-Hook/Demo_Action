+static u64 is_target_pid(int tgid)
+{
+	unsigned int num = 0;
+
+	while (num < target_pids_num) {
+		if (target_pids[num] == tgid)
+			return num;
+		num++;
+	}
+
+	return MAX_PID_NUM;
+}
+
+bool is_target_tid(int tid)
+{
+	unsigned int num = 0;
+
+	while (num < target_tids_num) {
+		if (target_tids[num] == tid) {
+			return true;
+		}
+		num++;
+	}
+
+	return false;
+}
