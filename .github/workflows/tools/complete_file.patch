+static int process_exit_notifier(struct notifier_block *self,
+			unsigned long cmd, void *v)
+{
+	struct task_struct *p = v;
+
+	/* only boost background tasks */
+	if (boost_kill && bg_task(p)) {
+		rcu_read_lock();
+		do_boost_kill_task(p);
+		rcu_read_unlock();
+	}
+
+	return NOTIFY_OK;
+}
