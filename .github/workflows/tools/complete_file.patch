+#ifdef CONFIG_OPLUS_MULTI_LV_TL
+static inline unsigned long uag_multi_util_max(struct uag_gov_policy *sg_policy)
+{
+	unsigned long max = 0;
+	int i;
+
+	for (i = 0; i < UA_UTIL_SIZE; i++) {
+		if (max < sg_policy->multi_util[i])
+			max = sg_policy->multi_util[i];
+	}
+
+	return max;
+}
+#endif
