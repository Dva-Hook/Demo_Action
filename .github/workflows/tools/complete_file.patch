+	INVALIDATE,
+	PRIMARY_PREPARE_FRAME,
+	PRIMARY_FINISH_FRAME,
+	PRIMARY_POST_FRAME,
+	OTHER_PREPARE_FRAME,
+	OTHER_FINISH_FRAME,
+	OTHER_POST_FRAME,
+	POST_COMP,
+	GPU_BOOST_HINT_START = 100,
+	GPU_BOOST_HINT_END,
