+		/* reset core boost */
+		last_core_boost = false;
+		last_core_boost_ts = 0;
+		/* cb_do_core_boost_work(); */
+
+		/* reset acc */
+		cb->last_ts = 0;
+		cb->last_freq_update_ts = 0;
+		cb->acc = 0;
+		cb->cur_level = cb->max_level ? cb->max_level : 0;
+	}
+
+	if (self_activate)
+		wake_up_process(cb_task);
