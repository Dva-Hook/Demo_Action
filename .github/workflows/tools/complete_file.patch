+	if (is_vip_mvp(p))
+		ux_state |= SA_TYPE_MQ_VIP;
+
+	if (per_cpu(prev_ux_state, cpu) != ux_state) {
+		char buf[256];
+
+		snprintf(buf, sizeof(buf), "C|9999|Cpu%d_ux_state|%d\n", cpu, ux_state);
+		tracing_mark_write(buf);
+		per_cpu(prev_ux_state, cpu) = ux_state;
+	}
+}
