+void resched_timer_init(void)
+{
+#ifdef CONFIG_TICK_GRAN_RESCHED_TIMER
+	struct rq *rq;
+	struct oplus_rq *orq;
+	int i;
+
+	for_each_possible_cpu(i) {
+		rq = cpu_rq(i);
+		orq = get_oplus_rq(rq);
+		orq->cpu = i;
+		hrtimer_init(orq->resched_timer, CLOCK_MONOTONIC, HRTIMER_MODE_REL);
+		orq->resched_timer->function = &no_preempt_resched;
+	}
