+enum ofb_ctrl_cmd_id {
+	SET_FPS = 1,
+	BOOST_HIT,
+	END_FRAME,
+	SF_FRAME_MISSED,
+	SF_COMPOSE_HINT,
+	IS_HWUI_RT,
+	SET_TASK_TAGGING,
+	SET_SF_MSG_TRANS,
+	RELATED_SCHED_CONFIG,
