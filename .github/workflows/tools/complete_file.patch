+static inline bool is_same_uid(struct task_struct *p, struct task_struct *grp_ui)
+{
+	int p_uid, ui_uid;
+
+	if (p == NULL || grp_ui == NULL)
+		return false;
+
+	p_uid = task_uid(p).val;
+	ui_uid = task_uid(grp_ui).val;
+
+	return (p_uid == ui_uid);
+}
